# Copy this file to .dev.vars and replace the placeholder values.
# The SDK does not load environment files itself; use your preferred local-env loader.

# The value only, not "substack.sid=" and not a complete Cookie header.
SUBSTACK_SESSION_TOKEN=replace-with-your-session-token

# Required for publication-scoped methods, such as getNotes and publishNote.
SUBSTACK_PUBLICATION_URL=https://your-publication.substack.com

# Optional overrides.
SUBSTACK_BASE_URL=https://substack.com
SUBSTACK_SESSION_COOKIE_NAME=substack.sid
